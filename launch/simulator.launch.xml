<launch>
  <!-- Arguments -->
  <arg name="run_headless" default="false" />
  <arg name="publish_description" default="true" />
  <arg name="start_controller" default="true" />
  <arg name="use_sim_time" default="true" />
  <arg name="model_path" default="$(find-pkg-share antsy_simulation)/mujoco/antsy.xml" />
  <arg name="realtime_factor" default="1.0" />
  <arg name="state_publish_rate" default="50.0" />

  <!-- MuJoCo simulator -->
  <node pkg="antsy_simulation" exec="mujoco_simulator.py" name="mujoco_simulator" output="screen">
    <param name="model_path" value="$(var model_path)" />
    <param name="run_headless" value="$(var run_headless)" />
    <param name="realtime_factor" value="$(var realtime_factor)" />
    <param name="state_publish_rate" value="$(var state_publish_rate)" />
  </node>

  <!-- Robot description -->
  <include file="$(find-pkg-share antsy_description)/launch/description.launch.py" if="$(var publish_description)">
    <arg name="use_sim_time" value="$(var use_sim_time)" />
  </include>

  <!-- Gait controller -->
  <include file="$(find-pkg-share antsy_control)/launch/follow_velocity_rectangle.launch.xml" if="$(var start_controller)">
    <arg name="use_sim_time" value="$(var use_sim_time)" />
  </include>
</launch>
